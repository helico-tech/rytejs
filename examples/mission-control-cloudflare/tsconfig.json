{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["@cloudflare/workers-types"]
	},
	"include": ["worker", "shared", "client"],
	"exclude": ["node_modules", "dist"]
}
