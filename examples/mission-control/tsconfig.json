{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"rootDir": ".",
		"lib": ["ES2022", "DOM", "DOM.Iterable"]
	},
	"include": ["client", "shared"],
	"exclude": ["node_modules", "dist"]
}
