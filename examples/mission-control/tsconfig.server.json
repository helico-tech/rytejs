{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "./dist-server",
		"rootDir": ".",
		"lib": ["ES2022"],
		"types": ["bun-types"]
	},
	"include": ["server", "shared"],
	"exclude": ["node_modules", "dist", "client"]
}
