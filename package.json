{
	"name": "rytejs",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.6.2",
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format .",
		"format:fix": "biome format --fix .",
		"check": "turbo run typecheck test && biome check .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"turbo": "^2.0.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json}": [
			"biome check --no-errors-on-unmatched --fix"
		]
	}
}
