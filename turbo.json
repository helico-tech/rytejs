{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"test": {},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"@rytejs/docs#docs:api": {
			"dependsOn": ["^build"],
			"outputs": ["api/**"]
		},
		"@rytejs/docs#build": {
			"dependsOn": ["@rytejs/docs#docs:api"],
			"outputs": [".vitepress/dist/**"]
		}
	}
}
