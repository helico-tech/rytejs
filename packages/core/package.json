{
	"name": "@rytejs/core",
	"version": "0.6.0",
	"description": "Type-safe workflow engine with Zod validation and middleware pipelines",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./store": {
			"types": "./dist/store/index.d.ts",
			"import": "./dist/store/index.js",
			"require": "./dist/store/index.cjs"
		},
		"./reactor": {
			"types": "./dist/reactor/index.d.ts",
			"import": "./dist/reactor/index.js",
			"require": "./dist/reactor/index.cjs"
		},
		"./executor": {
			"types": "./dist/executor/index.d.ts",
			"import": "./dist/executor/index.js",
			"require": "./dist/executor/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "https://github.com/helico-tech/rytejs",
		"directory": "packages/core"
	},
	"homepage": "https://helico-tech.github.io/rytejs",
	"bugs": "https://github.com/helico-tech/rytejs/issues",
	"keywords": [
		"workflow",
		"state-machine",
		"typescript",
		"zod",
		"middleware"
	],
	"peerDependencies": {
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.8.0",
		"tsup": "^8.5.0",
		"typescript": "^5.9.0",
		"vitest": "^4.0.0",
		"zod": "^4.3.0"
	},
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"engines": {
		"node": ">=20"
	}
}
